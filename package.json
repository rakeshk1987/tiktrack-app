{
  "name": "tiktrack-app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "emulators": "npx firebase-tools emulators:start --only auth,firestore,storage",
    "emulators:data": "npx firebase-tools emulators:start --only auth,firestore,storage --import .firebase-data --export-on-exit",
    "local": "powershell -ExecutionPolicy Bypass -File scripts/start-local.ps1",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "firebase": "^10.12.0",
    "lucide-react": "^1.7.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.22.0",
    "tailwind-merge": "^2.2.0",
    "vite-plugin-pwa": "^0.17.0"
  },
  "devDependencies": {
    "@eslint/js": "^8.57.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^14.2.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20.10.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "@vitest/coverage-v8": "^1.2.0",
    "autoprefixer": "^10.4.27",
    "eslint": "^8.57.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.6",
    "globals": "^13.24.0",
    "jsdom": "^23.2.0",
    "postcss": "^8.5.9",
    "tailwindcss": "^3.4.0",
    "typescript": "~5.3.0",
    "typescript-eslint": "^7.0.0",
    "vite": "^5.1.0",
    "vitest": "^1.2.0"
  }
}
