{
  "name": "tiktrack-app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "emulators": "npx firebase-tools emulators:start --only auth,firestore,storage --import .firebase-data --export-on-exit",
    "emulators:clean": "npx firebase-tools emulators:start --only auth,firestore,storage",
    "emulators:data": "npm run emulators",
    "local": "node scripts/start-local.mjs",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "telegram:setup": "node scripts/setup-telegram.mjs",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@fullcalendar/core": "^6.1.20",
    "@fullcalendar/daygrid": "^6.1.20",
    "@fullcalendar/interaction": "^6.1.20",
    "@fullcalendar/list": "^6.1.20",
    "@fullcalendar/react": "^6.1.20",
    "@fullcalendar/timegrid": "^6.1.20",
    "clsx": "^2.1.1",
    "firebase": "^10.12.0",
    "lucide-react": "^1.7.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.22.0",
    "tailwind-merge": "^2.2.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^8.57.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^14.2.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20.10.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "@vitest/coverage-v8": "^1.2.0",
    "autoprefixer": "^10.4.27",
    "confbox": "^0.1.7",
    "dom-accessibility-api": "^0.6.3",
    "eslint": "^8.57.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.6",
    "firebase-admin": "^11.11.1",
    "firebase-functions": "^4.3.1",
    "firebase-tools": "^13.35.1",
    "globals": "^13.24.0",
    "jsdom": "^23.2.0",
    "postcss": "^8.5.9",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^7.0.0",
    "vite": "^5.1.0",
    "vite-plugin-pwa": "^0.20.5",
    "vitest": "^1.2.0",
    "workbox-build": "^7.1.1",
    "workbox-window": "^7.1.0"
  },
  "optionalDependencies": {
    "@rollup/rollup-linux-x64-gnu": "4.60.3"
  }
}
