rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function userDocExists(uid) {
      return exists(/databases/$(database)/documents/users/$(uid));
    }

    function userDoc(uid) {
      return get(/databases/$(database)/documents/users/$(uid));
    }

    function isParent() {
      return signedIn() && userDocExists(request.auth.uid) && (
        ('role' in userDoc(request.auth.uid).data && userDoc(request.auth.uid).data.role == 'parent_admin') ||
        ('role' in userDoc(request.auth.uid).data && userDoc(request.auth.uid).data.role == 'parent')
      );
    }

    function isChild() {
      return signedIn() && userDocExists(request.auth.uid) && 'role' in userDoc(request.auth.uid).data && userDoc(request.auth.uid).data.role == 'child_user';
    }

    function isSelf(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function isParentOf(childId) {
      return signedIn() && userDocExists(childId) && 'parent_id' in userDoc(childId).data && userDoc(childId).data.parent_id == request.auth.uid;
    }

    function familyIdFor(uid) {
      return userDocExists(uid) 
        ? (
            ('linked_family_id' in userDoc(uid).data && userDoc(uid).data.linked_family_id != null && userDoc(uid).data.linked_family_id != '')
              ? userDoc(uid).data.linked_family_id
              : (
                ('parent_id' in userDoc(uid).data && userDoc(uid).data.parent_id != null && userDoc(uid).data.parent_id != '')
                  ? userDoc(uid).data.parent_id
                  : uid
              )
          )
        : uid;
    }

    function sameFamily(familyId) {
      return signedIn() && familyId is string && familyId == familyIdFor(request.auth.uid);
    }

    function sameFamilyOnCreate() {
      return request.resource.data.family_id is string && sameFamily(request.resource.data.family_id);
    }

    function validChildScopedEventCreate() {
      return isChild() &&
        request.resource.data.child_id == request.auth.uid &&
        request.resource.data.created_by == 'child' &&
        request.resource.data.source == 'manual' &&
        (
          request.resource.data.category == 'personal' ||
          request.resource.data.category == 'custom' ||
          request.resource.data.category == 'homework'
        );
    }

    match /users/{userId} {
      allow read: if isSelf(userId) || isParent();
      allow create: if signedIn() && (isSelf(userId) || isParent());
      allow update: if isSelf(userId) || isParent();
      allow delete: if isParent();
    }

    match /child_profile/{childId} {
      allow read: if isSelf(childId) || isParentOf(childId) || isParent();
      allow create: if isParentOf(childId) || isParent();
      allow update: if isParentOf(childId) || isParent() || isSelf(childId);
      allow delete: if isParent();
    }

    match /tasks/{taskId} {
      allow read: if signedIn();
      allow create: if isParent() || (isChild() && request.resource.data.child_id == request.auth.uid);
      allow update: if isParent() || (
        isChild() &&
        resource.data.child_id == request.auth.uid &&
        resource.data.get('approval_status', '') != 'approved' &&
        request.resource.data.get('approval_status', '') == resource.data.get('approval_status', '')
      );
      allow delete: if isParent() || (isChild() && resource.data.child_id == request.auth.uid);
    }

    match /task_logs/{logId} {
      allow read: if isParent() || resource == null || isSelf(resource.data.child_id) || isParentOf(resource.data.child_id);
      allow create: if signedIn() && (
        (isChild() && request.resource.data.child_id == request.auth.uid) ||
        (isParent() && isParentOf(request.resource.data.child_id))
      );
      allow update: if isParent() || (isChild() && resource.data.child_id == request.auth.uid);
      allow delete: if isParent();
    }

    match /proof_logs/{proofId} {
      allow read: if isParent() || resource == null || isSelf(resource.data.child_id) || isParentOf(resource.data.child_id);
      allow create: if isChild() && request.resource.data.child_id == request.auth.uid;
      allow update: if isParent() || (isChild() && resource.data.child_id == request.auth.uid);
      allow delete: if isParent();
    }

    match /mood_logs/{moodId} {
      allow read: if isParent() || resource == null || isSelf(resource.data.child_id) || isParentOf(resource.data.child_id);
      allow create, update: if isChild() && request.resource.data.child_id == request.auth.uid;
      allow delete: if isParent();
    }

    match /diary_entries/{entryId} {
      allow read: if isParent() || resource == null || isSelf(resource.data.child_id) || isParentOf(resource.data.child_id);
      allow create, update: if isChild() && request.resource.data.child_id == request.auth.uid;
      allow delete: if isParent() || (isChild() && resource.data.child_id == request.auth.uid);
    }

    match /exam_results/{examId} {
      allow read: if isParent() || resource == null || isSelf(resource.data.child_id) || isParentOf(resource.data.child_id);
      allow create, update, delete: if isParent();
    }

    match /exams/{examId} {
      allow read: if signedIn();
      allow create: if isParent() || (isChild() && request.resource.data.child_id == request.auth.uid);
      allow update: if isParent() || (isChild() && resource.data.child_id == request.auth.uid);
      allow delete: if isParent() || (isChild() && resource.data.child_id == request.auth.uid);
    }

    match /growth_logs/{growthId} {
      allow read: if isParent() || resource == null || isSelf(resource.data.child_id) || isParentOf(resource.data.child_id);
      allow create: if isParent() || (isChild() && request.resource.data.child_id == request.auth.uid);
      allow update: if isParent() || (isChild() && resource.data.child_id == request.auth.uid);
      allow delete: if isParent();
    }

    match /special_dates/{specialDateId} {
      allow read: if isParent() || resource == null || isSelf(resource.data.child_id) || isParentOf(resource.data.child_id);
      allow create: if isParent() || (isChild() && request.resource.data.child_id == request.auth.uid);
      allow update: if isParent() || (isChild() && resource.data.child_id == request.auth.uid);
      allow delete: if isParent() || (isChild() && resource.data.child_id == request.auth.uid);
    }

    match /sick_periods/{sickPeriodId} {
      allow read: if isParent() || resource == null || isSelf(resource.data.child_id) || isParentOf(resource.data.child_id);
      allow create: if isParent() || (isChild() && request.resource.data.child_id == request.auth.uid);
      allow update: if isParent() || (isChild() && resource.data.child_id == request.auth.uid);
      allow delete: if isParent();
    }

    match /routines/{routineId} {
      // Child can read routines assigned to them or to all children
      allow read: if signedIn() && (
        isParent() ||
        resource == null ||
        resource.data.family_id == familyIdFor(request.auth.uid) ||
        resource.data.child_id == request.auth.uid ||
        resource.data.child_id == null ||
        resource.data.child_id == ''
      );
      // Parent can create any; child can create their own (goes to approval)
      allow create: if isParent() || (
        isChild() &&
        request.resource.data.child_id == request.auth.uid &&
        request.resource.data.created_by == 'child' &&
        request.resource.data.family_id is string
      );
      allow update: if isParent() || (
        isChild() && (
          resource.data.child_id == request.auth.uid ||
          resource.data.child_id == null ||
          resource.data.child_id == ''
        )
      );
      allow delete: if isParent();
    }

    match /routine_logs/{logId} {
      allow read: if isParent() || resource == null || isSelf(resource.data.child_id) || isParentOf(resource.data.child_id);
      allow create: if isParent() || (isChild() && request.resource.data.child_id == request.auth.uid);
      allow update: if isParent() || (isChild() && resource.data.child_id == request.auth.uid);
      allow delete: if isParent();
    }

    match /approvals/{approvalId} {
      allow read: if isParent() || resource == null || isSelf(resource.data.child_id) || isParentOf(resource.data.child_id);
      allow create: if isParent() || (isChild() && request.resource.data.child_id == request.auth.uid);
      allow update: if isParent() || (isChild() && resource.data.child_id == request.auth.uid);
      allow delete: if isParent();
    }

    match /settlements/{settlementId} {
      allow read: if isParent() || resource == null || isSelf(resource.data.child_id) || isParentOf(resource.data.child_id);
      allow create: if isParent();
      allow update: if isParent();
      allow delete: if isParent();
    }

    match /money_pot_entries/{entryId} {
      allow read: if isParent() || resource == null || isSelf(resource.data.child_id) || isParentOf(resource.data.child_id);
      allow create: if isParent() || (isChild() && request.resource.data.child_id == request.auth.uid);
      allow update: if isParent() || (isChild() && resource.data.child_id == request.auth.uid);
      allow delete: if isParent() || (isChild() && resource.data.child_id == request.auth.uid);
    }

    match /money_pot_targets/{targetId} {
      allow read: if isParent() || resource == null || isSelf(resource.data.child_id) || isParentOf(resource.data.child_id);
      allow create: if isParent() || (isChild() && request.resource.data.child_id == request.auth.uid);
      allow update: if isParent() || (isChild() && resource.data.child_id == request.auth.uid);
      allow delete: if isParent() || (isChild() && resource.data.child_id == request.auth.uid);
    }

    match /events/{eventId} {
      allow read: if signedIn() && (
        (resource.data.family_id is string && sameFamily(resource.data.family_id)) ||
        (resource.data.child_id is string && (isSelf(resource.data.child_id) || isParentOf(resource.data.child_id)))
      );
      allow create: if sameFamilyOnCreate() && (isParent() || validChildScopedEventCreate());
      allow update: if isParent() || (
        isChild() &&
        resource.data.child_id == request.auth.uid &&
        (
          resource.data.category == 'personal' ||
          resource.data.category == 'custom' ||
          resource.data.category == 'homework'
        ) &&
        request.resource.data.child_id == resource.data.child_id &&
        request.resource.data.created_by == resource.data.created_by &&
        request.resource.data.parent_id == resource.data.parent_id
      );
      allow delete: if isParent();
    }

    match /programs/{programId} {
      allow read: if signedIn() && (
        (resource.data.family_id is string && sameFamily(resource.data.family_id)) ||
        (resource.data.child_id is string && (isSelf(resource.data.child_id) || isParentOf(resource.data.child_id))) ||
        isParent()
      );
      // Allow parent to create/update/delete programs for their family.
      // sameFamily() is preferred but falls back to plain isParent() to handle
      // edge-cases where linked_family_id is not yet propagated to the auth token.
      allow create, update: if isParent() && (
        !('family_id' in request.resource.data) ||
        sameFamily(request.resource.data.family_id) ||
        request.resource.data.family_id == request.auth.uid
      );
      allow delete: if isParent() && (
        !('family_id' in resource.data) ||
        sameFamily(resource.data.family_id) ||
        resource.data.family_id == request.auth.uid
      );
    }

    match /school_timetables/{docId} {
      allow read: if (
        (resource.data.family_id is string && sameFamily(resource.data.family_id)) ||
        isParent() || isSelf(resource.data.child_id) || isParentOf(resource.data.child_id)
      );
      allow create, update: if (
        (isParent() && (
          !('family_id' in request.resource.data) ||
          sameFamily(request.resource.data.family_id)
        )) ||
        (isChild() && request.resource.data.child_id == request.auth.uid && sameFamily(request.resource.data.family_id))
      );
      allow delete: if isParent();
    }

    match /achievements/{achievementId} {
      allow read: if isParent() || resource == null || isSelf(resource.data.child_id) || isParentOf(resource.data.child_id);
      allow create: if isChild() && request.resource.data.child_id == request.auth.uid;
      allow update: if isParent() || (
        isChild() &&
        resource.data.child_id == request.auth.uid &&
        resource.data.get('approval_status', '') != 'approved' &&
        request.resource.data.get('approval_status', '') == resource.data.get('approval_status', '')
      );
      allow delete: if isParent() || (isChild() && resource.data.child_id == request.auth.uid);
    }

    match /challenges/{challengeId} {
      allow read: if signedIn();
      allow create, update, delete: if isParent();
    }

    match /shields/{shieldId} {
      allow read: if isParent() || resource == null || isSelf(resource.data.child_id) || isParentOf(resource.data.child_id);
      allow create, update, delete: if isParent();
    }

    match /reward_settings/{settingId} {
      allow read: if signedIn() && (
        ('family_id' in resource.data && sameFamily(resource.data.family_id)) ||
        resource.data.parent_id == request.auth.uid ||
        isParent()
      );
      allow create, update: if isParent() && (
        !('family_id' in request.resource.data) ||
        sameFamily(request.resource.data.family_id)
      );
      allow delete: if isParent() && (
        !('family_id' in resource.data) ||
        sameFamily(resource.data.family_id)
      );
    }

    match /routine_configurations/{routineId} {
      allow read: if signedIn() && (
        isParent() ||
        resource.data.child_id == request.auth.uid ||
        resource.data.child_id == ''
      );
      allow create, update, delete: if isParent();
    }

    match /reminders/{reminderId} {
      allow read: if isParent() || resource == null || isSelf(resource.data.child_id) || isParentOf(resource.data.child_id);
      allow create, update, delete: if isParent();
    }

    match /reminder_logs/{logId} {
      allow read: if isParent() || resource == null || isSelf(resource.data.child_id) || isParentOf(resource.data.child_id);
      allow create, update, delete: if isParent();
    }

    match /reward_items/{rewardId} {
      allow read: if signedIn() && (
        ('family_id' in resource.data && sameFamily(resource.data.family_id)) ||
        isParent() ||
        (resource.data.child_id is string && isParentOf(resource.data.child_id))
      );
      allow create, update: if isParent() && (
        !('family_id' in request.resource.data) ||
        sameFamily(request.resource.data.family_id)
      );
      allow delete: if isParent() && (
        !('family_id' in resource.data) ||
        sameFamily(resource.data.family_id)
      );
    }

    match /reward_ledger/{entryId} {
      allow read: if isParent() || resource == null || isSelf(resource.data.child_id) || isParentOf(resource.data.child_id);
      allow create: if isParent() || (isChild() && request.resource.data.child_id == request.auth.uid);
      allow update: if isParent() || (
        isChild() &&
        resource.data.child_id == request.auth.uid &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['surprise_state', 'revealed_at'])
      );
      allow delete: if isParent();
    }

    match /scratch_rewards/{scratchId} {
      allow read: if isParent() || resource == null || isSelf(resource.data.child_id) || isParentOf(resource.data.child_id);
      allow create: if isParent() || (
        isChild() &&
        request.resource.data.child_id == request.auth.uid &&
        request.resource.data.source_id is string &&
        request.resource.data.source_type in ['task', 'routine', 'approval']
      );
      allow update: if isParent() || (
        isChild() &&
        resource.data.child_id == request.auth.uid &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'revealed_at'])
      );
      allow delete: if isParent();
    }

    match /scratch_reward_templates/{templateId} {
      allow read: if signedIn() && (
        isParent() ||
        ('family_id' in resource.data && sameFamily(resource.data.family_id)) ||
        (resource.data.child_id is string && isSelf(resource.data.child_id))
      );
      allow create, update, delete: if isParent() && (
        !('family_id' in request.resource.data) ||
        sameFamily(request.resource.data.family_id)
      );
    }

    match /telegram_link_codes/{codeId} {
      allow read: if false;
      allow create: if isParent() && sameFamilyOnCreate() && request.resource.data.parent_id == request.auth.uid;
      allow update: if false;
      allow delete: if isParent() && resource.data.parent_id == request.auth.uid;
    }

    match /telegram_settings/{familyId} {
      allow read: if isParent() && sameFamily(familyId);
      allow create, update: if isParent() &&
        familyId == request.resource.data.family_id &&
        sameFamily(request.resource.data.family_id);
      allow delete: if isParent() && sameFamily(familyId);
    }

    match /telegram_links/{telegramUserId} {
      allow read, write: if false;
    }

    match /telegram_sessions/{telegramUserId} {
      allow read, write: if false;
    }

    match /redemptions/{redemptionId} {
      allow read: if isParent() || resource == null || isSelf(resource.data.child_id) || isParentOf(resource.data.child_id);
      allow create: if isChild() && request.resource.data.child_id == request.auth.uid;
      allow update, delete: if isParent();
    }

    match /planner_subjects/{subjectId} {
      allow read: if signedIn() && (
        isParent() ||
        resource.data.childId == request.auth.uid ||
        resource.data.familyId == familyIdFor(request.auth.uid) ||
        isParentOf(resource.data.childId)
      );
      allow create: if signedIn() && (
        isParent() || 
        request.resource.data.childId == request.auth.uid
      );
      allow update: if signedIn() && (
        isParent() || 
        resource.data.childId == request.auth.uid ||
        request.resource.data.childId == request.auth.uid
      );
      allow delete: if signedIn() && (
        isParent() || 
        resource.data.childId == request.auth.uid
      );
    }

    match /messages/{messageId} {
      allow read: if signedIn() && (
        isParent() ||
        resource.data.child_id == request.auth.uid ||
        resource.data.parent_id == request.auth.uid ||
        isParentOf(resource.data.child_id)
      );
      allow create: if signedIn() && (
        isParent() ||
        request.resource.data.child_id == request.auth.uid ||
        request.resource.data.parent_id == request.auth.uid
      );
      allow update: if isParent() || (
        isChild() &&
        resource.data.child_id == request.auth.uid &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['is_read'])
      );
      allow delete: if isParent();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
