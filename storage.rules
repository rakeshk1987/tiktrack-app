rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    match /proofs/{childId}/{allPaths=**} {
      allow read, write: if signedIn();
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
